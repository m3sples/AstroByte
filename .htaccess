Options -MultiViews
RewriteEngine On
RewriteBase /

# Forzar HTTPS (redirección 301)
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirigir index.php a la raíz (URL limpia)
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

# Redirigir /home a la raíz (evita contenido duplicado)
RewriteRule ^home/?$ / [R=301,L]

# Quitar .php de cualquier otra URL (ej: contacto.php -> /contacto)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteCond %1 !^index$ [NC]
RewriteRule ^ %1 [R=301,L]

# Si existe archivo o carpeta real, no reescribir
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Reescribir URLs sin extensión a .php (solo si el archivo existe)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L,QSA]
